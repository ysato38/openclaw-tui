{
  "name": "openclaw-tui",
  "version": "0.1.0",
  "description": "OpenClaw Mission Control TUI",
  "type": "module",
  "bin": {
    "openclaw-tui": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.tsx --format esm --dts --out-dir dist --clean",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "tui",
    "ink"
  ],
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.13.11",
    "@types/react": "^18.3.19",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
